# =====================================================
# VoiceVault Sui - Centralized Environment Configuration
# =====================================================

# Wallet Address
SUI_ADDRESS=0x00fe9f516cc03adabcb1c521ecb82f9d2c5c9a42102b5e9895939b63d098df70
SUI_ALIAS=cool-alexandrite

# Network
SUI_NETWORK=testnet
SUI_RPC_URL=https://fullnode.testnet.sui.io
SUI_FULL_NODE_URL=https://fullnode.testnet.sui.io:443

# Gas Budget
SUI_GAS_BUDGET=10000000

# Smart Contracts (from Published.toml)
SUI_PACKAGE_ID=0xfad2808bcd104197b53b1fddede5f25d5c16303b147d280c2aa7ff69d27e5d59
SUI_UPGRADE_CAPABILITY=0x11104c8cc167bad70c519ca855c10ec71d8f97114d33e38888d388c4d39b6f30

# VoiceRegistry Object ID (created by init_registry)
# TODO: Update after running: sui client call --function init_registry --package {SUI_PACKAGE_ID}
# Command: sui client call --function init_registry --package 0xfad2808bcd104197b53b1fddede5f25d5c16303b147d280c2aa7ff69d27e5d59 --gas-budget 10000000
SUI_VOICE_REGISTRY_ID=0xfad2808bcd104197b53b1fddede5f25d5c16303b147d280c2aa7ff69d27e5d59

# =====================================================
# FRONTEND CONFIGURATION (Vite)
# =====================================================

# API Server
VITE_API_URL=http://localhost:8000
VITE_PROXY_URL=http://localhost:8000
VITE_BACKEND_URL=http://localhost:8000

# Walrus Configuration
VITE_WALRUS_AGGREGATOR_URL=http://localhost:8000/api/walrus

# Sui Configuration (exposed to frontend)
VITE_SUI_NETWORK=testnet
VITE_SUI_RPC_URL=https://fullnode.testnet.sui.io
VITE_SUI_PACKAGE_ID=0xfad2808bcd104197b53b1fddede5f25d5c16303b147d280c2aa7ff69d27e5d59
VITE_SUI_VOICE_REGISTRY_ID=0xfad2808bcd104197b53b1fddede5f25d5c16303b147d280c2aa7ff69d27e5d59


# =====================================================
# BACKEND CONFIGURATION
# =====================================================

# Server Port
PORT=8000
BACKEND_URL=http://localhost:8000

# Walrus Storage
WALRUS_STORAGE_MODE=local
WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space
WALRUS_AGGREGATOR_URL=http://localhost:8000/api/walrus
WALRUS_EPOCHS=5
WALRUS_DELETABLE=true
WALRUS_MAX_BLOB_SIZE=10485760

# Walrus CLI Configuration (for remote deployments)
PATH_TO_WALRUS=/path/to/walrus
PATH_TO_WALRUS_CONFIG=~/.config/walrus/client_config.yaml

# API Security
API_SECRET_KEY=your_secret_key_here
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173", "http://localhost:8000"]

# Logging
LOG_LEVEL=info

# =====================================================